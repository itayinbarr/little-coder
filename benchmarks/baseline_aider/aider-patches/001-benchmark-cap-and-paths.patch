+# Per-exercise wall-clock cap. Overridable via AIDER_PER_EXERCISE_CAP_SECONDS env var.
+# Applied via SIGALRM around run_test_real; on fire, the exercise is marked failed
+# with an exceeded_wall_cap marker and the benchmark moves on.
+_PER_EXERCISE_CAP_SECONDS = int(os.environ.get("AIDER_PER_EXERCISE_CAP_SECONDS", "3600"))
+
+
+class PerExerciseTimeout(BaseException):
+    """Inherits from BaseException so Aider/litellm's broad `except Exception:`
+    retry clauses cannot swallow it. Only our own `except PerExerciseTimeout`
+    in run_test() catches it."""
+    pass
+
+
+def _per_exercise_timeout_handler(signum, frame):
+    raise PerExerciseTimeout()
